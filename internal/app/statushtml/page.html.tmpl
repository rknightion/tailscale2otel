<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Service.Name}} — status</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='6' fill='%234493f8'/%3E%3C/svg%3E">
<style>
  :root{
    --bg:#0f1419; --panel:#171c24; --panel2:#1d242e; --line:#2a323d;
    --fg:#e6edf3; --muted:#8b98a5; --accent:#4493f8;
    --ok:#3fb950; --warn:#d29922; --err:#f85149; --pending:#6e7681;
    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--fg);
    font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif}
  a{color:var(--accent);text-decoration:none}
  a:hover{text-decoration:underline}
  code{font-family:var(--mono);font-size:12px;background:var(--panel2);
    padding:1px 5px;border-radius:4px;color:#c9d1d9}
  header{padding:20px 24px;border-bottom:1px solid var(--line);
    display:flex;align-items:baseline;gap:14px;flex-wrap:wrap}
  header h1{margin:0;font-size:20px;font-weight:600}
  header .ver{color:var(--muted);font-family:var(--mono);font-size:13px}
  header .spacer{flex:1}
  main{max-width:1180px;margin:0 auto;padding:20px 24px 60px}
  section{margin:26px 0}
  section>h2{font-size:13px;text-transform:uppercase;letter-spacing:.06em;
    color:var(--muted);margin:0 0 12px;font-weight:600}
  .cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:12px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:14px 16px}
  .card .k{color:var(--muted);font-size:12px;margin-bottom:6px}
  .card .v{font-size:20px;font-weight:600;font-variant-numeric:tabular-nums}
  .card .sub{color:var(--muted);font-size:12px;margin-top:4px;font-family:var(--mono);
    overflow-wrap:anywhere}
  .badge{display:inline-block;padding:2px 9px;border-radius:999px;font-size:12px;
    font-weight:600;line-height:1.6}
  .badge.ok{background:rgba(63,185,80,.16);color:var(--ok)}
  .badge.err{background:rgba(248,81,73,.16);color:var(--err)}
  .badge.warn{background:rgba(210,153,34,.16);color:var(--warn)}
  .badge.pending{background:rgba(110,118,129,.18);color:var(--muted)}
  table{width:100%;border-collapse:collapse;background:var(--panel);
    border:1px solid var(--line);border-radius:10px;overflow:hidden}
  th,td{text-align:left;padding:8px 12px;border-bottom:1px solid var(--line);
    font-variant-numeric:tabular-nums;vertical-align:top}
  th{color:var(--muted);font-size:12px;font-weight:600;position:sticky;top:0;
    background:var(--panel2)}
  tr:last-child td{border-bottom:0}
  td.num{text-align:right;font-family:var(--mono)}
  tr.bad>td{background:rgba(248,81,73,.07)}
  .mono{font-family:var(--mono);font-size:12px;overflow-wrap:anywhere}
  details{background:var(--panel);border:1px solid var(--line);border-radius:10px}
  details>summary{cursor:pointer;padding:12px 16px;font-weight:600;user-select:none}
  details[open]>summary{border-bottom:1px solid var(--line)}
  details table{border:0;border-radius:0}
  .filter{width:100%;max-width:340px;margin-bottom:10px;padding:7px 11px;
    background:var(--panel2);border:1px solid var(--line);border-radius:8px;
    color:var(--fg);font-size:13px}
  .scroll{max-height:460px;overflow:auto;border:1px solid var(--line);border-radius:10px}
  .scroll table{border:0;border-radius:0}
  .muted{color:var(--muted)}
  .note{color:var(--muted);font-size:12px;margin-top:2px}
  .note.err{color:var(--err)}
  /* Per-collector info affordance: a small ⓘ whose popover (purpose + emitted
     metrics) is positioned with fixed coords by JS so the collectors table's
     overflow:hidden can't clip it. The server-rendered no-JS fallback uses a
     native title= tooltip on the same .collector-info span. */
  .collector-info{position:relative;display:inline-block;margin-left:6px;
    color:var(--muted);font-size:12px;line-height:1;cursor:help;user-select:none}
  .collector-info:hover,.collector-info:focus{color:var(--accent);outline:none}
  .cinfo-tip{position:fixed;left:0;top:0;z-index:50;display:none;width:360px;
    max-height:340px;overflow:auto;background:var(--panel2);
    border:1px solid var(--line);border-radius:8px;padding:10px 12px;
    box-shadow:0 8px 24px rgba(0,0,0,.5);
    font-weight:400;text-transform:none;letter-spacing:normal;white-space:normal;
    text-align:left;cursor:auto}
  .collector-info:hover .cinfo-tip,.collector-info:focus .cinfo-tip{display:block}
  .cinfo-purpose{display:block;color:var(--fg);font-size:12px;line-height:1.5}
  .cinfo-metrics{display:block;margin-top:8px;padding-top:8px;
    border-top:1px solid var(--line)}
  .cinfo-m{display:block;margin:7px 0}
  .cinfo-m code{font-size:11px}
  .cinfo-d{display:block;color:var(--muted);font-size:11px;line-height:1.45;
    margin-top:2px}
  footer{max-width:1180px;margin:0 auto;padding:0 24px 40px;color:var(--muted);font-size:12px}
  nav.toc{position:sticky;top:0;z-index:5;display:flex;gap:16px;flex-wrap:wrap;
    padding:10px 24px;background:rgba(15,20,25,.93);border-bottom:1px solid var(--line);
    backdrop-filter:blur(4px);font-size:13px}
  .reasons{padding:6px 24px;color:var(--warn);font-size:12px;font-family:var(--mono);
    border-bottom:1px solid var(--line)}
  #staleBanner{display:none;padding:8px 24px;background:rgba(210,153,34,.16);
    color:var(--warn);font-size:13px;border-bottom:1px solid var(--line)}
  #staleBanner.show{display:block}
  svg.spark{width:80px;height:22px;vertical-align:middle;display:inline-block}
  svg.spark.card{width:100%;height:36px;display:block;margin-top:8px}
  .outcome{display:inline-flex;gap:2px;align-items:center}
  .outcome i{width:5px;height:14px;border-radius:1px;background:var(--ok);display:inline-block}
  .outcome i.f{background:var(--err)}
  .controls{display:inline-flex;gap:10px;align-items:center}
  button.ctl{background:var(--panel2);color:var(--fg);border:1px solid var(--line);
    border-radius:7px;padding:4px 10px;font-size:12px;cursor:pointer;font-family:inherit}
  button.ctl:hover{border-color:var(--accent)}
</style>
</head>
<body>
<header>
  <h1>{{.Service.Name}}</h1>
  <span class="ver">{{.Service.Version}} · {{.Service.GoVersion}}</span>
  {{if .Service.Tailnet}}<span class="ver">tailnet {{.Service.Tailnet}}</span>{{end}}
  <span class="spacer"></span>
  <span class="badge {{healthClass .Health}}" id="healthBadge" title="{{range .HealthReasons}}{{.}}&#10;{{end}}">{{.Health}}</span>
</header>
<div class="reasons" id="healthReasons"{{if not .HealthReasons}} style="display:none"{{end}}>{{range .HealthReasons}}{{.}} · {{end}}</div>
<div id="staleBanner"></div>
<nav class="toc">
  <a href="#collectors">Collectors</a>
  <a href="#api">API</a>
  <a href="#cardinality">Cardinality</a>
  <a href="#nodemetrics">Node metrics</a>
  {{if .Devices}}<a href="#devices">Devices</a>{{end}}
  <a href="#rdns">Reverse DNS</a>
  <a href="#metrics">Metrics</a>
  <a href="#logs">Logs</a>
  <a href="#config">Config</a>
</nav>
<main>

  <section>
    <div class="cards">
      <div class="card"><div class="k">Uptime</div><div class="v" id="uptime">{{.Service.Uptime}}</div><div class="sub">since {{.Service.StartedAt}}</div></div>
      <div class="card"><div class="k">OTLP export</div><div class="v">{{.Telemetry.Protocol}}</div><div class="sub">{{if .Telemetry.Endpoint}}{{.Telemetry.Endpoint}}{{else}}—{{end}} · {{.Telemetry.MetricIntervalS}}s</div></div>
      <div class="card"><div class="k">Self-observability</div><div class="v">{{if .Service.SelfObs}}<span class="badge ok">on</span>{{else}}<span class="badge pending">off</span>{{end}}</div></div>
      {{if .Provider}}<div class="card"><div class="k">Control plane</div><div class="v"><code>{{.Provider}}</code></div>{{if .Capabilities}}<div class="sub">{{range $i,$c := .Capabilities}}{{if $i}}, {{end}}{{$c}}{{end}}</div>{{end}}</div>{{end}}
      <div class="card"><div class="k">Devices cached</div><div class="v" id="cacheDevices">{{.Cache.Devices}}</div><div class="sub">age <span id="cacheAge">{{.Cache.Age}}</span></div></div>
      <div class="card"><div class="k">Goroutines</div><div class="v" id="goroutines">{{.Runtime.Goroutines}}</div><div class="sub">GOMAXPROCS {{.Runtime.GOMAXPROCS}}</div><svg class="spark card" id="goroutinesSpark"></svg></div>
      <div class="card"><div class="k">Heap in use</div><div class="v" id="heapAlloc">{{.Runtime.HeapAlloc}}</div><div class="sub">GC cycles <span id="numGC">{{.Runtime.NumGC}}</span></div><svg class="spark card" id="heapSpark"></svg></div>
      <div class="card"><div class="k">GC rate</div><div class="v" id="gcRate">—</div><div class="sub">cycles/sec</div><svg class="spark card" id="gcRateSpark"></svg></div>
    </div>
  </section>

  {{if gt (len .Tailnets) 1}}
  <section id="tailnets">
    <h2>Tailnets ({{len .Tailnets}})</h2>
    <table>
      <thead><tr><th>Tailnet</th><th>Auth</th><th class="num">Devices</th><th class="num">Collectors</th><th class="num">Failing</th></tr></thead>
      <tbody>
      {{range .Tailnets}}
        <tr>
          <td><code>{{.Name}}</code></td>
          <td>{{.AuthMethod}}</td>
          <td class="num">{{.Cache.Devices}}</td>
          <td class="num">{{len .Collectors}}</td>
          <td class="num">{{if gt .Failing 0}}<span class="badge degraded">{{.Failing}}</span>{{else}}—{{end}}</td>
        </tr>
      {{end}}
      </tbody>
    </table>
    <p class="note">Per-tailnet detail is available in <a href="/api/status.json"><code>/api/status.json</code></a> under <code>tailnets[]</code>. The Collectors, Devices and API sections below show the combined view across all tailnets.</p>
  </section>
  {{end}}

  <section id="collectors">
    <h2>Collectors</h2>
    <table>
      <thead><tr><th>Collector</th><th>Status</th><th class="num">Interval</th><th class="num">Success</th><th class="num">Runs</th><th class="num">Failures</th><th class="num">Next run</th><th class="num">Duration</th><th>Recent</th><th>Last error</th></tr></thead>
      <tbody id="collBody">
      {{range .Collectors}}
        <tr{{if and .HasRun (not .LastSuccess)}} class="bad"{{end}}>
          <td><code>{{.Name}}</code>{{if .Description}} <span class="collector-info" tabindex="0" title="{{.Description}}{{range .Metrics}}&#10;• {{.Name}} — {{.Description}}{{end}}">&#9432;</span>{{end}}{{with .Checkpoint}}<div class="note{{if .Stuck}} err{{end}}">checkpoint lag {{.Lag}}{{if .Stuck}} · stuck{{end}}</div>{{end}}</td>
          <td>{{if not .HasRun}}<span class="badge pending">pending</span>{{else if .LastSuccess}}<span class="badge ok">ok</span>{{else}}<span class="badge err">fail</span>{{end}}</td>
          <td class="num">{{.IntervalSec}}s</td>
          <td class="num">{{if .HasRun}}{{printf "%.0f" .SuccessRatePct}}%{{else}}<span class="muted">—</span>{{end}}</td>
          <td class="num">{{.Runs}}</td>
          <td class="num">{{.Failures}}{{if gt .ConsecutiveFailures 0}} <span class="muted">({{.ConsecutiveFailures}}×)</span>{{end}}</td>
          <td class="num">{{if .HasRun}}{{if le .NextRunInSec 0}}due{{else}}{{.NextRunIn}}{{end}}{{else}}<span class="muted">—</span>{{end}}</td>
          <td class="num">{{if .HasRun}}{{.LastDurationMs}}ms{{else}}<span class="muted">—</span>{{end}}</td>
          <td></td>
          <td class="mono">{{if .LastError}}{{.LastError}}{{else}}<span class="muted">—</span>{{end}}</td>
        </tr>
      {{else}}
        <tr><td colspan="10" class="muted">No collectors enabled.</td></tr>
      {{end}}
      </tbody>
    </table>
  </section>

  <section id="api">
    <h2>API health</h2>
    <div class="cards" style="margin-bottom:12px">
      <div class="card" id="rateLimitCard"{{if not .API.RateLimit}} style="display:none"{{end}}>
        <div class="k">Rate limited (429)</div>
        <div class="v" id="rlCount">{{with .API.RateLimit}}{{.Count}}{{end}}</div>
        <div class="sub">last <span id="rlLast">{{with .API.RateLimit}}{{.LastSeen}}{{end}}</span></div>
      </div>
    </div>
    <div class="scroll">
    <table>
      <thead><tr><th>Endpoint</th><th class="num">Requests</th><th class="num">Errors</th><th class="num">Retries</th><th class="num">429s</th><th class="num">Last status</th><th class="num">Latency</th><th>Last error</th></tr></thead>
      <tbody id="apiBody">
      {{range .API.Endpoints}}
        <tr>
          <td><code>{{.Endpoint}}</code></td>
          <td class="num">{{.Requests}}</td>
          <td class="num">{{.Errors}}</td>
          <td class="num">{{.Retries}}</td>
          <td class="num">{{.RateLimited}}</td>
          <td class="num">{{.LastStatus}}</td>
          <td class="num"><span class="muted">—</span></td>
          <td class="mono">{{if .LastError}}{{.LastError}}{{else}}<span class="muted">—</span>{{end}}</td>
        </tr>
      {{else}}
        <tr><td colspan="8" class="muted">No API requests recorded yet.</td></tr>
      {{end}}
      </tbody>
    </table>
    </div>
  </section>

  <section id="cardinality">
    <h2>Cardinality (active series, last export interval)</h2>
    {{if .Cardinality.Available}}
      <div class="cards" style="margin-bottom:12px">
        <div class="card"><div class="k">Total active series</div><div class="v" id="cardTotal">{{.Cardinality.Total}}</div><div class="sub">across {{len .Cardinality.Series}} metrics</div><svg class="spark card" id="cardSpark"></svg></div>
      </div>
      <input class="filter" type="text" placeholder="Filter metrics…" oninput="filterTable(this,'cardTable')">
      <div class="scroll">
      <table id="cardTable">
        <thead><tr><th>Metric</th><th>Prometheus name</th><th class="num">Series</th></tr></thead>
        <tbody>
        {{range .Cardinality.Series}}
          <tr><td><code>{{.Metric}}</code></td><td class="mono">{{.PromName}}</td><td class="num">{{.Count}}{{if .Capped}} <span class="badge warn" title="cap reached; true cardinality is at least this high">capped</span>{{end}}</td></tr>
        {{end}}
        </tbody>
      </table>
      </div>
    {{else}}
      <p class="muted">{{if .Service.SelfObs}}Awaiting the first export interval…{{else}}Enable <code>self_observability</code> to surface live active-series cardinality.{{end}}</p>
    {{end}}
  </section>

  <section id="nodemetrics">
    <h2>Node-metrics discovery</h2>
    {{if .NodeDiscovery.Enabled}}
      <details>
        <summary>{{.NodeDiscovery.Active}} active target(s) · {{.NodeDiscovery.Static}} static, {{minus .NodeDiscovery.Active .NodeDiscovery.Static}} discovered
          {{if .NodeDiscovery.LastOK}}<span class="badge ok">last discovery ok</span>{{else}}<span class="badge err">last discovery failed</span>{{end}}
          {{if .NodeDiscovery.LastDiscovery}}<span class="muted" style="font-weight:400"> at {{.NodeDiscovery.LastDiscovery}}</span>{{end}}
        </summary>
        <table>
          <thead><tr><th>Instance</th><th>URL</th><th>Source</th></tr></thead>
          <tbody>
          {{range .NodeDiscovery.Targets}}
            <tr><td>{{if .Instance}}<code>{{.Instance}}</code>{{else}}<span class="muted">—</span>{{end}}</td><td class="mono">{{.URL}}</td><td>{{if eq .Source "discovered"}}<span class="badge ok">discovered</span>{{else}}<span class="badge pending">static</span>{{end}}</td></tr>
          {{else}}
            <tr><td colspan="3" class="muted">No active targets.</td></tr>
          {{end}}
          </tbody>
        </table>
      </details>
    {{else}}
      <p class="muted">Dynamic discovery is disabled. {{if gt .NodeDiscovery.Static 0}}Scraping {{.NodeDiscovery.Static}} static target(s).{{end}}</p>
    {{end}}
  </section>

  {{if .Devices}}
  <section id="devices">
    <h2>Devices ({{len .Devices}})</h2>
    <details>
      <summary>{{len .Devices}} device(s) in the enrichment cache</summary>
      <input class="filter" type="text" placeholder="Filter devices…" oninput="filterTable(this,'devTable')" style="margin:12px 16px">
      <div class="scroll">
      <table id="devTable">
        <thead><tr><th>Name</th><th>OS</th><th>User</th><th>Addresses</th><th>Tags</th><th>External</th></tr></thead>
        <tbody>
        {{range .Devices}}
          <tr>
            <td><code>{{if .Name}}{{.Name}}{{else}}{{.Hostname}}{{end}}</code></td>
            <td>{{.OS}}{{if .OSVersion}} {{.OSVersion}}{{end}}</td>
            <td>{{.User}}</td>
            <td class="mono">{{range .Addrs}}{{.}} {{end}}</td>
            <td class="mono">{{range .Tags}}<code>{{.}}</code> {{end}}</td>
            <td>{{if .External}}<span class="badge warn">external</span>{{else}}<span class="badge pending">internal</span>{{end}}</td>
          </tr>
        {{end}}
        </tbody>
      </table>
      </div>
    </details>
  </section>
  {{end}}

  <section id="rdns">
    <h2>Reverse DNS (PTR) cache</h2>
    {{if .RDNS.Enabled}}
    <div class="cards">
      <div class="card"><div class="k">Entries</div><div class="v" id="rdnsSize">{{.RDNS.Size}}</div><div class="sub">of {{.RDNS.Capacity}} max</div></div>
      <div class="card"><div class="k">Hit rate</div><div class="v" id="rdnsHitRate">{{printf "%.1f" .RDNS.HitRatePct}}%</div><div class="sub">hit <span id="rdnsHits">{{.RDNS.Hits}}</span> · miss <span id="rdnsMisses">{{.RDNS.Misses}}</span> · neg <span id="rdnsNegatives">{{.RDNS.Negatives}}</span></div></div>
      <div class="card"><div class="k">Resolver queries</div><div class="v" id="rdnsQueries">{{add64 .RDNS.QuerySuccess .RDNS.QueryFail}}</div><div class="sub">ok <span id="rdnsQuerySuccess">{{.RDNS.QuerySuccess}}</span> · fail <span id="rdnsQueryFail">{{.RDNS.QueryFail}}</span></div></div>
      <div class="card"><div class="k">Overflows</div><div class="v" id="rdnsOverflows">{{.RDNS.Overflows}}</div><div class="sub">at-capacity drops{{if .RDNS.Overflows}} — raise max_entries{{end}}</div></div>
      <div class="card"><div class="k">Evictions</div><div class="v" id="rdnsEvicted">{{add64 .RDNS.EvictedExpired .RDNS.EvictedPurged}}</div><div class="sub">expired <span id="rdnsEvictedExpired">{{.RDNS.EvictedExpired}}</span> · purged <span id="rdnsEvictedPurged">{{.RDNS.EvictedPurged}}</span></div></div>
      <div class="card"><div class="k">TTL</div><div class="v" style="font-size:16px">{{.RDNS.TTL}}</div><div class="sub">negative {{.RDNS.NegativeTTL}}</div></div>
    </div>
    <div class="controls" style="margin-top:12px">
      <button class="ctl" id="rdnsPurgeBtn">Purge cache</button>
      <span class="muted" id="rdnsPurgeMsg">{{if .RDNS.LastPurge}}last purged {{.RDNS.LastPurge}}{{end}}</span>
    </div>
    {{else}}
    <p class="muted">Reverse-DNS enrichment is disabled (<code>enrichment.reverse_dns.enabled=false</code>). External flow addresses stay bucketed as <code>external</code>; no PTR lookups are made.</p>
    {{end}}
  </section>

  <section id="metrics">
    <h2>Metrics catalog ({{len .Metrics}})</h2>
    <input class="filter" type="text" placeholder="Filter metrics…" oninput="filterTable(this,'metricsTable')">
    <div class="scroll">
    <table id="metricsTable">
      <thead><tr><th>Name</th><th>Prometheus name</th><th>Type</th><th>Unit</th><th>Group</th>{{if .Service.SelfObs}}<th class="num">Series</th>{{end}}<th>Attributes</th></tr></thead>
      <tbody>
      {{range .Metrics}}
        <tr>
          <td><code>{{.Name}}</code><div class="note" style="margin:2px 0 0">{{.Description}}</div></td>
          <td class="mono">{{.PromName}}</td>
          <td>{{.Instrument}}</td>
          <td>{{if .Unit}}<code>{{.Unit}}</code>{{end}}</td>
          <td>{{.Group}}</td>
          {{if $.Service.SelfObs}}<td class="num">{{if gt .Series 0}}{{.Series}}{{else}}<span class="muted">—</span>{{end}}</td>{{end}}
          <td class="mono">{{range .Attributes}}<code>{{.}}</code> {{end}}</td>
        </tr>
      {{end}}
      </tbody>
    </table>
    </div>
  </section>

  <section id="logs">
    <h2>Log events ({{len .LogEvents}})</h2>
    <input class="filter" type="text" placeholder="Filter log events…" oninput="filterTable(this,'logsTable')">
    <div class="scroll">
    <table id="logsTable">
      <thead><tr><th>Event</th><th>Severity</th><th>Group</th><th>Attributes</th></tr></thead>
      <tbody>
      {{range .LogEvents}}
        <tr>
          <td><code>{{.Name}}</code><div class="note" style="margin:2px 0 0">{{.Description}}</div></td>
          <td>{{.Severity}}</td>
          <td>{{.Group}}</td>
          <td class="mono">{{range .Attributes}}<code>{{.}}</code> {{end}}</td>
        </tr>
      {{end}}
      </tbody>
    </table>
    </div>
  </section>

  <section id="config">
    <h2>Configuration (secrets redacted)</h2>
    <div class="cards">
      <div class="card"><div class="k">Log level</div><div class="v" style="font-size:16px">{{.Config.LogLevel}}</div></div>
      <div class="card"><div class="k">Auth method</div><div class="v" style="font-size:16px">{{.Config.AuthMethod}}</div></div>
      <div class="card"><div class="k">Checkpoint store</div><div class="v" style="font-size:16px">{{.Config.CheckpointStore}}</div></div>
      <div class="card"><div class="k">Receivers</div><div class="v" style="font-size:16px">{{if .Receivers.Streaming}}<span class="badge ok">stream</span> {{end}}{{if .Receivers.Webhook}}<span class="badge ok">webhook</span>{{end}}{{if and (not .Receivers.Streaming) (not .Receivers.Webhook)}}<span class="muted">none</span>{{end}}</div></div>
      <div class="card"><div class="k">Profiling</div><div class="v" style="font-size:16px">{{if .Profiling.PprofEnabled}}<span class="badge ok">pprof</span> {{end}}{{if .Profiling.PyroscopeEnabled}}<span class="badge ok">pyroscope</span>{{end}}{{if and (not .Profiling.PprofEnabled) (not .Profiling.PyroscopeEnabled)}}<span class="muted">off</span>{{end}}</div>{{if .Profiling.PyroscopeServer}}<div class="sub">{{.Profiling.PyroscopeServer}}</div>{{end}}</div>
    </div>
    <table style="margin-top:12px">
      <tbody>
        <tr><td>Enabled collectors</td><td class="mono">{{range .Config.EnabledCollectors}}<code>{{.}}</code> {{end}}</td></tr>
        <tr><td>Secrets configured</td><td class="mono">
          {{if .Config.APIKeySet}}<code>api_key</code> {{end}}
          {{if .Config.OAuthSecretSet}}<code>oauth_secret</code> {{end}}
          {{if .Config.GCloudTokenSet}}<code>grafana_cloud_token</code> {{end}}
          {{if .Config.StreamTokenSet}}<code>stream_token</code> {{end}}
          {{if .Config.WebhookSecretSet}}<code>webhook_secret</code> {{end}}
          {{if .Config.PyroscopeAuthSet}}<code>pyroscope_auth</code> {{end}}
        </td></tr>
        {{if .Config.OTLPHeaderKeys}}<tr><td>OTLP header keys</td><td class="mono">{{range .Config.OTLPHeaderKeys}}<code>{{.}}</code> {{end}}</td></tr>{{end}}
        {{if .Dedup}}<tr><td>Dedup sets</td><td class="mono">{{range .Dedup}}{{.Name}} {{.Len}}/{{.Capacity}} &nbsp;{{end}}</td></tr>{{end}}
      </tbody>
    </table>
  </section>

</main>
<footer>
  Generated at <span id="generatedAt">{{.GeneratedAt}}</span> ·
  <a href="/api/status.json">JSON</a> ·
  <span class="controls"><button class="ctl" id="pauseBtn">Pause</button> <a href="#" id="refreshNow">refresh now</a></span> ·
  updated <span id="updatedAgo">just now</span> ·
  <noscript>static snapshot (enable JavaScript for live updates &amp; sparklines)</noscript>
</footer>
<script>
var SVGNS = 'http://www.w3.org/2000/svg';
var lastOkMs = Date.now();
var pollTimer = null, paused = false;

// Filter table rows by a case-insensitive substring of their text content.
function filterTable(input, tableId){
  var q = input.value.toLowerCase();
  var rows = document.querySelectorAll('#'+tableId+' tbody tr');
  for (var i=0;i<rows.length;i++){
    rows[i].style.display = rows[i].textContent.toLowerCase().indexOf(q) > -1 ? '' : 'none';
  }
}

function setText(id, v){ var e=document.getElementById(id); if(e!=null&&v!=null) e.textContent=v; }

function el(tag, attrs, text){
  var e=document.createElement(tag);
  if(attrs){ for(var k in attrs){ if(attrs.hasOwnProperty(k)) e.setAttribute(k, attrs[k]); } }
  if(text!=null) e.textContent=text;
  return e;
}

// relText renders an RFC3339 timestamp as a coarse "Nm ago" string.
function relText(iso){
  if(!iso) return '';
  var t = Date.parse(iso); if(isNaN(t)) return iso;
  return relMs(t);
}
function relMs(ms){
  var s = Math.round((Date.now()-ms)/1000); if(s<0) s=0;
  if(s<60) return s+'s ago';
  if(s<3600) return Math.floor(s/60)+'m ago';
  if(s<86400) return Math.floor(s/3600)+'h ago';
  return Math.floor(s/86400)+'d ago';
}

// drawSpark renders a min/max-normalized polyline into an inline <svg> from a
// numeric array. Fewer than two points clears the svg (nothing to plot).
function drawSpark(svg, arr, color){
  if(!svg) return;
  while(svg.firstChild) svg.removeChild(svg.firstChild);
  if(!arr || arr.length < 2) return;
  var W=100, H=24, pad=2, n=arr.length, mn=arr[0], mx=arr[0], i;
  for(i=1;i<n;i++){ if(arr[i]<mn) mn=arr[i]; if(arr[i]>mx) mx=arr[i]; }
  var span=(mx-mn)||1, pts='';
  for(i=0;i<n;i++){
    var x=pad + i*(W-2*pad)/(n-1);
    var y=H-pad - (arr[i]-mn)/span*(H-2*pad);
    pts += (i?' ':'') + x.toFixed(1)+','+y.toFixed(1);
  }
  svg.setAttribute('viewBox','0 0 '+W+' '+H);
  svg.setAttribute('preserveAspectRatio','none');
  var pl=document.createElementNS(SVGNS,'polyline');
  pl.setAttribute('fill','none');
  pl.setAttribute('stroke', color || 'var(--accent)');
  pl.setAttribute('stroke-width','1.5');
  pl.setAttribute('vector-effect','non-scaling-stroke');
  pl.setAttribute('points', pts);
  svg.appendChild(pl);
}
function newSpark(){ var s=document.createElementNS(SVGNS,'svg'); s.setAttribute('class','spark'); return s; }

// outcomeStrip renders the last <=24 run outcomes as red/green cells.
function outcomeStrip(arr){
  var span=el('span',{'class':'outcome'});
  if(!arr) return span;
  var start = arr.length>24 ? arr.length-24 : 0;
  for(var i=start;i<arr.length;i++){
    var dot=el('i'); if(!arr[i]) dot.className='f';
    dot.title = arr[i] ? 'ok' : 'fail';
    span.appendChild(dot);
  }
  return span;
}

function statusBadge(c){
  if(!c.has_run) return el('span',{'class':'badge pending'},'pending');
  if(c.last_success) return el('span',{'class':'badge ok'},'ok');
  return el('span',{'class':'badge err'},'fail');
}

// collectorInfo builds the ⓘ affordance for a collector: a small icon whose
// popover lists the collector's purpose and the metrics it emits. The popover is
// position:fixed and placed on hover/focus so the table's overflow:hidden can't
// clip it. Returns null when the collector carries no doc data.
function collectorInfo(c){
  if(!c.description && !(c.metrics && c.metrics.length)) return null;
  var wrap=el('span',{'class':'collector-info','tabindex':'0','aria-label':'About '+c.name});
  wrap.appendChild(document.createTextNode('ⓘ'));
  var tip=el('span',{'class':'cinfo-tip'});
  if(c.description) tip.appendChild(el('span',{'class':'cinfo-purpose'}, c.description));
  if(c.metrics && c.metrics.length){
    var list=el('span',{'class':'cinfo-metrics'});
    c.metrics.forEach(function(m){
      var row=el('span',{'class':'cinfo-m'});
      row.appendChild(el('code',null,m.name));
      if(m.description) row.appendChild(el('span',{'class':'cinfo-d'}, m.description));
      list.appendChild(row);
    });
    tip.appendChild(list);
  }
  wrap.appendChild(tip);
  function place(){
    var r=wrap.getBoundingClientRect(), w=360, left=r.left, top=r.bottom;
    if(left+w > window.innerWidth-8) left=window.innerWidth-8-w;
    if(left<8) left=8;
    tip.style.left=Math.round(left)+'px';
    tip.style.top=Math.round(top)+'px';
  }
  wrap.addEventListener('mouseenter', place);
  wrap.addEventListener('focus', place);
  return wrap;
}

function rebuildCollectors(rows){
  var tb=document.getElementById('collBody'); if(!tb) return;
  tb.textContent='';
  if(!rows || !rows.length){
    var tr0=el('tr'); tr0.appendChild(el('td',{'colspan':'10','class':'muted'},'No collectors enabled.'));
    tb.appendChild(tr0); return;
  }
  rows.forEach(function(c){
    var tr=el('tr');
    if((c.has_run && !c.last_success) || c.consecutive_failures>=3 || c.overdue || (c.checkpoint && c.checkpoint.stuck)) tr.className='bad';
    var nameTd=el('td'); nameTd.appendChild(el('code',null,c.name));
    var info=collectorInfo(c); if(info) nameTd.appendChild(info);
    if(c.checkpoint){
      var sub=el('div',{'class':'note'+(c.checkpoint.stuck?' err':'')});
      sub.textContent='checkpoint lag '+c.checkpoint.lag+(c.checkpoint.stuck?' · stuck':'');
      nameTd.appendChild(sub);
    }
    tr.appendChild(nameTd);
    var stTd=el('td'); stTd.appendChild(statusBadge(c)); tr.appendChild(stTd);
    tr.appendChild(el('td',{'class':'num'}, c.interval_seconds+'s'));
    tr.appendChild(el('td',{'class':'num'}, c.has_run ? Math.round(c.success_rate_pct)+'%' : '—'));
    tr.appendChild(el('td',{'class':'num'}, String(c.runs)));
    tr.appendChild(el('td',{'class':'num'}, String(c.failures)+(c.consecutive_failures>0?' ('+c.consecutive_failures+'×)':'')));
    tr.appendChild(el('td',{'class':'num'}, c.has_run ? (c.next_run_in_seconds<=0?'due':c.next_run_in) : '—'));
    var durTd=el('td',{'class':'num'});
    durTd.appendChild(document.createTextNode(c.has_run ? c.last_duration_ms+'ms ' : '— '));
    if(c.duration_ms_series && c.duration_ms_series.length>1){ var sp=newSpark(); durTd.appendChild(sp); drawSpark(sp, c.duration_ms_series); }
    tr.appendChild(durTd);
    var recTd=el('td'); recTd.appendChild(outcomeStrip(c.outcome_series)); tr.appendChild(recTd);
    var errTd=el('td',{'class':'mono'});
    if(c.last_error){ errTd.textContent=c.last_error; } else { errTd.appendChild(el('span',{'class':'muted'},'—')); }
    tr.appendChild(errTd);
    tb.appendChild(tr);
  });
}

function rebuildAPI(info){
  var tb=document.getElementById('apiBody'); if(!tb) return;
  var eps = (info && info.endpoints) ? info.endpoints : [];
  tb.textContent='';
  if(!eps.length){
    var tr0=el('tr'); tr0.appendChild(el('td',{'colspan':'8','class':'muted'},'No API requests recorded yet.'));
    tb.appendChild(tr0);
  } else {
    eps.forEach(function(e2){
      var tr=el('tr');
      var nameTd=el('td'); nameTd.appendChild(el('code',null,e2.endpoint)); tr.appendChild(nameTd);
      tr.appendChild(el('td',{'class':'num'}, String(e2.requests)));
      tr.appendChild(el('td',{'class':'num'}, String(e2.errors)));
      tr.appendChild(el('td',{'class':'num'}, String(e2.retries)));
      tr.appendChild(el('td',{'class':'num'}, String(e2.rate_limited)));
      tr.appendChild(el('td',{'class':'num'}, e2.last_status ? String(e2.last_status) : '—'));
      var latTd=el('td',{'class':'num'});
      var s=e2.duration_ms_series;
      if(s && s.length){ latTd.appendChild(document.createTextNode(s[s.length-1]+'ms ')); } else { latTd.appendChild(el('span',{'class':'muted'},'—')); }
      if(s && s.length>1){ var sp=newSpark(); latTd.appendChild(sp); drawSpark(sp, s); }
      tr.appendChild(latTd);
      var errTd=el('td',{'class':'mono'});
      if(e2.last_error){ errTd.textContent=e2.last_error; } else { errTd.appendChild(el('span',{'class':'muted'},'—')); }
      tr.appendChild(errTd);
      tb.appendChild(tr);
    });
  }
  var rl=document.getElementById('rateLimitCard');
  if(rl){
    if(info && info.rate_limit){
      rl.style.display='';
      setText('rlCount', info.rate_limit.count);
      setText('rlLast', info.rate_limit.last_seen ? relText(info.rate_limit.last_seen) : '—');
    } else { rl.style.display='none'; }
  }
}

function updateSparks(d){
  if(d.runtime){
    drawSpark(document.getElementById('goroutinesSpark'), d.runtime.goroutines_series);
    drawSpark(document.getElementById('heapSpark'), d.runtime.heap_alloc_series);
    drawSpark(document.getElementById('gcRateSpark'), d.runtime.gc_rate_series, 'var(--warn)');
    var gr=d.runtime.gc_rate_series;
    if(gr && gr.length) setText('gcRate', gr[gr.length-1].toFixed(2)+'/s');
  }
  if(d.cardinality) drawSpark(document.getElementById('cardSpark'), d.cardinality.total_series);
}

function setHealth(d){
  var b=document.getElementById('healthBadge'); if(b){
    b.textContent=d.health;
    b.className='badge '+(d.health==='healthy'?'ok':d.health==='degraded'?'err':'pending');
    b.title=(d.health_reasons||[]).join('\n');
  }
  var rb=document.getElementById('healthReasons');
  if(rb){
    if(d.health_reasons && d.health_reasons.length){ rb.textContent=d.health_reasons.join(' · '); rb.style.display=''; }
    else { rb.style.display='none'; }
  }
}

function setStale(on){
  var b=document.getElementById('staleBanner'); if(!b) return;
  if(on){ b.className='show'; b.textContent='⚠ disconnected — last successful update '+relMs(lastOkMs); }
  else { b.className=''; }
}

function refresh(){
  fetch('/api/status.json',{cache:'no-store'}).then(function(r){
    if(!r.ok) throw new Error('status '+r.status);
    return r.json();
  }).then(function(d){
    lastOkMs=Date.now(); setStale(false);
    setText('uptime', d.service && d.service.uptime);
    setText('goroutines', d.runtime && d.runtime.goroutines);
    setText('heapAlloc', d.runtime && d.runtime.heap_alloc);
    setText('numGC', d.runtime && d.runtime.num_gc);
    setText('cacheDevices', d.device_cache && d.device_cache.devices);
    setText('cacheAge', d.device_cache && d.device_cache.age);
    updateRDNS(d.reverse_dns);
    if(d.cardinality) setText('cardTotal', d.cardinality.total);
    setText('generatedAt', d.generated_at);
    setHealth(d);
    rebuildCollectors(d.collectors);
    rebuildAPI(d.api);
    updateSparks(d);
  }).catch(function(){ setStale(true); });
}

function updateRDNS(r){
  if(!r || !r.enabled) return;
  setText('rdnsSize', r.size);
  setText('rdnsHitRate', (r.hit_rate_pct!=null?r.hit_rate_pct.toFixed(1):'0.0')+'%');
  setText('rdnsHits', r.hits); setText('rdnsMisses', r.misses); setText('rdnsNegatives', r.negatives);
  setText('rdnsQueries', (r.query_success||0)+(r.query_fail||0));
  setText('rdnsQuerySuccess', r.query_success); setText('rdnsQueryFail', r.query_fail);
  setText('rdnsOverflows', r.overflows);
  setText('rdnsEvicted', (r.evicted_expired||0)+(r.evicted_purged||0));
  setText('rdnsEvictedExpired', r.evicted_expired); setText('rdnsEvictedPurged', r.evicted_purged);
}
function purgeRDNS(){
  if(!confirm('Purge the reverse-DNS cache? Cached PTR names will be re-resolved on the next sighting.')) return;
  var btn=document.getElementById('rdnsPurgeBtn'); if(btn) btn.disabled=true;
  fetch('/api/rdns/purge',{method:'POST',headers:{'X-Requested-With':'fetch'},cache:'no-store'})
    .then(function(r){ if(!r.ok) throw new Error('status '+r.status); return r.json(); })
    .then(function(d){ var m=document.getElementById('rdnsPurgeMsg'); if(m) m.textContent='purged '+d.purged+' entr'+(d.purged===1?'y':'ies'); refresh(); })
    .catch(function(e){ var m=document.getElementById('rdnsPurgeMsg'); if(m) m.textContent='purge failed: '+e.message; })
    .finally(function(){ if(btn) btn.disabled=false; });
}
function startPolling(){ if(pollTimer) clearInterval(pollTimer); pollTimer=setInterval(refresh, 10000); }
function togglePause(){
  paused=!paused;
  var btn=document.getElementById('pauseBtn');
  if(paused){ if(pollTimer){clearInterval(pollTimer); pollTimer=null;} if(btn) btn.textContent='Resume'; }
  else { if(btn) btn.textContent='Pause'; refresh(); startPolling(); }
}
function tickFreshness(){
  setText('updatedAgo', relMs(lastOkMs));
  var b=document.getElementById('staleBanner');
  if(b && b.className.indexOf('show')>=0) setStale(true);
}

(function init(){
  var p=document.getElementById('pauseBtn'); if(p) p.addEventListener('click', togglePause);
  var rn=document.getElementById('refreshNow'); if(rn) rn.addEventListener('click', function(ev){ ev.preventDefault(); refresh(); });
  var pb=document.getElementById('rdnsPurgeBtn'); if(pb) pb.addEventListener('click', purgeRDNS);
  refresh();
  startPolling();
  setInterval(tickFreshness, 1000);
})();
</script>
</body>
</html>
